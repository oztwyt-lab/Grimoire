{
  "expo": {
    "name": "Grimor",
    "slug": "Grimoire",
    "scheme": "grimoire",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/ui/splash_screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#16213e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adioco.grimor"
    },
    "android": {
      "newArchEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.adioco.grimor",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-audio",
        {
          "recordAudioAndroid": false
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "9116fa85-9fa6-4f0a-b103-050874fb59d1"
      }
    },
    "owner": "ozexpoz"
  }
}
